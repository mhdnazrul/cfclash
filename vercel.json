{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sync-codeforces-cron",
      "schedule": "0 0 */2 * *" 
    }
  ]
}
